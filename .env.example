# Copy to .env and fill in secrets

POSTGRES_USER=vinted
POSTGRES_PASSWORD=vinted
POSTGRES_DB=vinted_tracker

# Shared by API + frontend (X-Api-Key)
API_KEY=change-me-to-a-long-secret

# Feature flag: Vinted tracker UI + worker polling (false = only lumpeksy map)
ENABLE_VINTED=false

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=

# Worker tuning
OFFER_RETENTION_DAYS=10
POLL_MIN_SECONDS=7
POLL_MAX_SECONDS=15
SESSION_REFRESH_MINUTES=20
VINTED_BASE_URL=https://www.vinted.pl
CORS_ORIGINS=*
